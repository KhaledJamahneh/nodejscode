# Einhod Pure Water - Environment Configuration
# Copy this file to .env and fill in your actual values

# Server Configuration
NODE_ENV=development
PORT=3000
API_VERSION=v1

# Database Configuration
# Option 1: Use DATABASE_URL for cloud databases (Neon, Heroku, etc.)
# DATABASE_URL=postgresql://user:password@hostname:port/dbname?sslmode=require

# Option 2: Use individual connection parameters for local databases
DB_HOST=localhost
DB_PORT=5432
DB_NAME=einhod_water
DB_USER=postgres
DB_PASSWORD=your_secure_password_here

# Database Pool Configuration (optional - defaults shown)
DB_POOL_SIZE=20
DB_IDLE_TIMEOUT=30000
DB_CONNECTION_TIMEOUT=2000
DB_ALLOW_INSECURE_SSL=false

# JWT Authentication
JWT_SECRET=b8cf9761c6c4e7b273a44136d3073a909031560f21fdecc24584ee2c4dc1d004ae9a39a42d5c1e34fe2dc9c98395bd54b0447b21d6e0664303fce252718eac6b
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=3f91f4ab62d48af348bf31362c4a1a4264bae87c6e0458ed11e84b5566690a5e7f228cfe4a763c87a5ae5ba4ccc8f32f21a2440e12b86a7adbd047d017aff6f4
JWT_REFRESH_EXPIRES_IN=7d

# Security
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# File Upload
MAX_FILE_SIZE_MB=10
UPLOAD_DIR=./uploads

# Google Maps API (for geocoding and distance calculations)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Firebase Cloud Messaging (for push notifications)
FCM_SERVER_KEY=your_firebase_server_key_here

# Payment Gateway (example: Stripe)
PAYMENT_GATEWAY_API_KEY=your_payment_gateway_key_here
PAYMENT_GATEWAY_SECRET=your_payment_gateway_secret_here

# Email Service (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_email_password

# SMS Service (optional - Twilio example)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Logging
LOG_LEVEL=info
LOG_FILE_PATH=./logs/app.log

# CORS
CORS_ORIGIN=http://localhost:3001,http://localhost:8080

# System Settings
GPS_UPDATE_INTERVAL_SECONDS=30
PROXIMITY_NOTIFICATION_RADIUS_KM=1
LOW_INVENTORY_THRESHOLD=10
SESSION_TIMEOUT_HOURS=24
